{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "."
      }
    }
  ],
  "routes": [
    {
      "src": "/models/map_city.glb",
      "dest": "https://github.com/ybeststudio/Metin2-Web-Client/releases/download/assets/map_city.glb"
    },
    {
      "src": "/ui/empire/empire_jinno169.jpeg",
      "dest": "/ui/empire/empire_jinno169.jpg"
    }
  ]
}
